# ============================================================
# Environment Variables — video-to-script-mvp
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to source control.
# ============================================================

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Gemini AI (required)
GEMINI_API_KEY=your_gemini_api_key

# IP throttle salt — a random string used to anonymize hashed IPs
# Generate with: openssl rand -hex 32
IP_HASH_SALT=your_random_salt_string_here
